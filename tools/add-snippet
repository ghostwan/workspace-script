#!/bin/bash
# Author: ghostwan@gmail.com
# Description: Add a snippet to Alfred and commit/push the change

ALFRED_SNIPPETS_DIR="$HOME/workspace/configs/alfred/Alfred.alfredpreferences/snippets"
ALFRED_REPO_DIR="$HOME/workspace/configs/alfred"

DEBUG=false

# --- Colors ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m' # No Color

usage() {
  echo
  echo " Usage: ${0##*/} [options]"
  echo
  echo " Description: Add a snippet to Alfred, then commit and push the change."
  echo
  echo " Options:"
  echo "   -n, --name        Snippet name"
  echo "   -s, --snippet     Snippet content (use \\n for newlines)"
  echo "   -k, --keyword     Auto-expansion keyword (default: empty)"
  echo "   -c, --collection  Collection name (existing or new)"
  echo "   -d, --debug       Debug mode: create the snippet but don't commit/push"
  echo "   -h, --help        Show this help message"
  echo
  echo " If options are omitted, the script will prompt for them interactively."
  echo
}

# --- Parse arguments ---
SNIPPET_NAME=""
SNIPPET_CONTENT=""
SNIPPET_KEYWORD=""
COLLECTION=""

while [[ $# -gt 0 ]]; do
  case $1 in
    -n|--name)
      SNIPPET_NAME="$2"
      shift 2
      ;;
    -s|--snippet)
      SNIPPET_CONTENT="$2"
      shift 2
      ;;
    -k|--keyword)
      SNIPPET_KEYWORD="$2"
      shift 2
      ;;
    -c|--collection)
      COLLECTION="$2"
      shift 2
      ;;
    -d|--debug)
      DEBUG=true
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    -*)
      echo -e "${RED}Unknown option: $1${NC}"
      usage
      exit 1
      ;;
    *)
      echo -e "${RED}Unexpected argument: $1${NC}"
      usage
      exit 1
      ;;
  esac
done

# --- Interactive prompts for missing values ---

# Collection
if [[ -z "$COLLECTION" ]]; then
  echo -e "${BOLD}Available collections:${NC}"
  collections=()
  i=1
  for dir in "$ALFRED_SNIPPETS_DIR"/*/; do
    name=$(basename "$dir")
    collections+=("$name")
    echo -e "  ${CYAN}$i)${NC} $name"
    ((i++))
  done
  echo -e "  ${CYAN}$i)${NC} ${YELLOW}[Create new collection]${NC}"
  echo
  read -rp "Choose a collection (number): " choice

  if [[ "$choice" -eq "$i" ]]; then
    read -rp "New collection name: " COLLECTION
  elif [[ "$choice" -ge 1 && "$choice" -lt "$i" ]]; then
    COLLECTION="${collections[$((choice - 1))]}"
  else
    echo -e "${RED}Invalid choice.${NC}"
    exit 1
  fi
fi

# Name
if [[ -z "$SNIPPET_NAME" ]]; then
  read -rp "Snippet name: " SNIPPET_NAME
fi

if [[ -z "$SNIPPET_NAME" ]]; then
  echo -e "${RED}Snippet name cannot be empty.${NC}"
  exit 1
fi

# Content
if [[ -z "$SNIPPET_CONTENT" ]]; then
  echo -e "Snippet content (press ${CYAN}Ctrl+D${NC} on an empty line when done):"
  SNIPPET_CONTENT=$(cat)
fi

if [[ -z "$SNIPPET_CONTENT" ]]; then
  echo -e "${RED}Snippet content cannot be empty.${NC}"
  exit 1
fi

# Keyword (optional, default empty)
if [[ -z "$SNIPPET_KEYWORD" ]]; then
  read -rp "Auto-expansion keyword (leave empty for none): " SNIPPET_KEYWORD
fi

# --- Generate UUID ---
UUID=$(uuidgen | tr '[:lower:]' '[:upper:]')

# --- Prepare collection directory ---
COLLECTION_DIR="$ALFRED_SNIPPETS_DIR/$COLLECTION"

if [[ ! -d "$COLLECTION_DIR" ]]; then
  echo -e "${YELLOW}Creating new collection: $COLLECTION${NC}"
  mkdir -p "$COLLECTION_DIR"

  # Create info.plist for the new collection
  cat > "$COLLECTION_DIR/info.plist" <<'PLIST'
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>snippetkeywordprefix</key>
	<string></string>
	<key>snippetkeywordsuffix</key>
	<string></string>
</dict>
</plist>
PLIST
fi

# --- Create snippet JSON file ---
SNIPPET_FILE="$COLLECTION_DIR/$SNIPPET_NAME [$UUID].json"

# Use python3 to safely produce JSON (handles escaping of special chars, newlines, etc.)
python3 -c "
import json, sys

data = {
    'alfredsnippet': {
        'snippet': sys.argv[1],
        'uid': sys.argv[2],
        'name': sys.argv[3],
        'keyword': sys.argv[4]
    }
}

print(json.dumps(data, indent=2, ensure_ascii=False))
" "$SNIPPET_CONTENT" "$UUID" "$SNIPPET_NAME" "$SNIPPET_KEYWORD" > "$SNIPPET_FILE"

if [[ $? -ne 0 ]]; then
  echo -e "${RED}Failed to create snippet file.${NC}"
  exit 1
fi

echo
echo -e "${GREEN}Snippet created:${NC}"
echo -e "  ${BOLD}Name:${NC}       $SNIPPET_NAME"
echo -e "  ${BOLD}Collection:${NC} $COLLECTION"
echo -e "  ${BOLD}Keyword:${NC}    ${SNIPPET_KEYWORD:-<none>}"
echo -e "  ${BOLD}UUID:${NC}       $UUID"
echo -e "  ${BOLD}File:${NC}       $SNIPPET_FILE"

if $DEBUG; then
  echo
  echo -e "${YELLOW}[DEBUG] Skipping git commit and push.${NC}"
  exit 0
fi

# --- Git commit and push ---
echo
echo -e "${CYAN}Committing and pushing...${NC}"

git -C "$ALFRED_REPO_DIR" add "$SNIPPET_FILE"

# Also add info.plist if it's a new collection
if git -C "$ALFRED_REPO_DIR" status --porcelain "$COLLECTION_DIR/info.plist" | grep -q '??'; then
  git -C "$ALFRED_REPO_DIR" add "$COLLECTION_DIR/info.plist"
fi

git -C "$ALFRED_REPO_DIR" commit -m "Add Alfred snippet: $SNIPPET_NAME ($COLLECTION)"

if [[ $? -ne 0 ]]; then
  echo -e "${RED}Git commit failed.${NC}"
  exit 1
fi

git -C "$ALFRED_REPO_DIR" push

if [[ $? -ne 0 ]]; then
  echo -e "${RED}Git push failed.${NC}"
  exit 1
fi

echo -e "${GREEN}Done! Snippet committed and pushed.${NC}"
